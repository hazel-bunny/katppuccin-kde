[General]
ColorScheme=Katppuccin--flavour--accentName
Name=Katppuccin --flavour --accentName
accentActiveTitlebar=false
shadeSortColumn=true


[KDE]
contrast=4
frameContrast=0.1

[WM]
activeBackground=$base
activeBlend=$overlay0
activeForeground=$text
inactiveBackground=$base
inactiveBlend=$surface2
inactiveForeground=$subtext0
