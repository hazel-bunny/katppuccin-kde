[ColorEffects:Disabled]
Color=$base
ColorAmount=0.5
ColorEffect=2
ContrastAmount=0.5
ContrastEffect=1
IntensityAmount=0.25
IntensityEffect=2

[ColorEffects:Inactive]
ChangeSelectionColor=true
Color=$base
ColorAmount=0.5
ColorEffect=2
ContrastAmount=0.25
ContrastEffect=2
Enable=false
IntensityAmount=0
IntensityEffect=0

[Colors:Button]
BackgroundAlternate=--accentColor
BackgroundNormal=$surface1
DecorationFocus=--accentColor
DecorationHover=--accentColor
ForegroundActive=$peach
ForegroundInactive=$subtext0
ForegroundLink=--accentColor
ForegroundNegative=$red
ForegroundNeutral=$yellow
ForegroundNormal=$text
ForegroundPositive=$green
ForegroundVisited=$mauve


[Colors:Complementary]
BackgroundAlternate=$base
BackgroundNormal=$crust
DecorationFocus=--accentColor
DecorationHover=$surface2
ForegroundActive=$peach
ForegroundInactive=$subtext0
ForegroundLink=--accentColor
ForegroundNegative=$red
ForegroundNeutral=$yellow
ForegroundNormal=$text
ForegroundPositive=$green
ForegroundVisited=$mauve


